{
  "name": "ai-news-dashboard-mission-control",
  "version": "2.0.0",
  "description": "Production-grade AI news intelligence dashboard with live updates, global mapping, enrichment pipeline, and admin controls",
  "type": "module",
  "scripts": {
    "dev": "npx concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "npx tsx src/server.ts",
    "client:dev": "npx vite",
    "build": "tsc && vite build",
    "start": "node dist/server.js",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "seed": "tsx src/db/seed.ts",
    "jobs:worker": "tsx src/jobs/worker.ts",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.1.2",
    "lodash": "^4.17.21",
    "node-cron": "^3.0.3",
    "redis": "^4.6.13",
    "rss-parser": "^3.13.0",
    "slugify": "^1.6.6",
    "uuid": "^9.0.1",
    "ws": "^8.15.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.10.6",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-react": "^4.2.1",
    "clsx": "^2.0.0",
    "concurrently": "^8.2.2",
    "date-fns": "^2.30.0",
    "eslint": "^8.55.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.294.0",
    "prisma": "^5.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "zustand": "^4.4.6"
  }
}