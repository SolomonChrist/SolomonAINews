# AI News Dashboard - Configuration

# API Keys (Optional - default free sources work without keys)
# YouTube API Key is needed for high-volume video searching
# Get a key at: https://console.cloud.google.com/
YOUTUBE_API_KEY="your_youtube_api_key_here"

# News APIs (Optional - for additional coverage)
NEWSAPI_KEY="your_newsapi_key_here"
NEWSDATA_KEY="your_newsdata_key_here"

# Server Config
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# Polling Defaults
DEFAULT_POLL_INTERVAL=3600
MAX_CONCURRENT_POLLS=5
